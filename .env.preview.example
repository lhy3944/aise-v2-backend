# === LLM API 설정 ===
LLM_PROVIDER=azure

# Azure OpenAI (회사용)
SRS_API_KEY=
SRS_ENDPOINT=
TC_API_KEY=
TC_ENDPOINT=

# OpenAI (개인용 - Azure 미사용 시)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# === Redis ===
REDIS_URL=redis://localhost:6380/0

# === LangGraph Checkpointer ===
LANGGRAPH_CHECKPOINT_URL=postgresql://aise:aise1234@localhost:5433/aise

# === Feature flags ===
USE_LANGGRAPH=false
