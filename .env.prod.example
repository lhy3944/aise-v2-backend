# === LLM API 설정 ===
LLM_PROVIDER=azure

# Azure OpenAI (회사용)
SRS_API_KEY=
SRS_ENDPOINT=
TC_API_KEY=
TC_ENDPOINT=

# OpenAI (개인용 - Azure 미사용 시)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# === Redis (LangGraph state cache, future Celery broker) ===
REDIS_URL=redis://localhost:6379/0

# === LangGraph Checkpointer (separate URL — sync psycopg, not asyncpg) ===
# Format: postgresql://user:pw@host:port/db   (NO +asyncpg)
LANGGRAPH_CHECKPOINT_URL=postgresql://aise:aise1234@localhost:5432/aise

# === Observability (Phase 4) ===
# Langfuse self-hosted by default. Switch to https://cloud.langfuse.com if approved.
# LANGFUSE_HOST=http://localhost:3030
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# === Feature flags ===
# Set to true to route /api/v1/agent/chat through the new LangGraph orchestrator.
# false = legacy agent_svc.stream_chat (Phase 0 baseline behavior).
USE_LANGGRAPH=false
